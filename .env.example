# Copy the toggle into .env and the wallet secret into .env.<network>:
#
#   cp .env.example .env            # then keep only MIDNIGHT_NETWORK
#   cp .env.example .env.preview    # then keep only the PREVIEW wallet lines
#   cp .env.example .env.preprod    # then keep only the PREPROD wallet lines
#
# All real .env* files are gitignored; only this example is committed.

# --- .env — network toggle: preview | preprod | local ------------------------
# (a MIDNIGHT_NETWORK set in the shell overrides this)
MIDNIGHT_NETWORK=preview

# --- .env.preview — wallet for the preview network ----------------------------
# Set ONE of the two. If neither is set, deploy generates a fresh seed and
# saves it here (that wallet then needs faucet funding).
MIDNIGHT_PREVIEW_MNEMONIC=word1 word2 word3 ... word24
#MIDNIGHT_PREVIEW_SEED=<64 hex chars>
# Contract owner key (auto-generated on first deploy if missing):
#COUNTER_SECRET_KEY=<64 hex chars>

# --- .env.preprod — wallet for the preprod network -----------------------------
#MIDNIGHT_PREPROD_MNEMONIC=word1 word2 word3 ... word24
#MIDNIGHT_PREPROD_SEED=<64 hex chars>
#COUNTER_SECRET_KEY=<64 hex chars>

# --- optional tuning -----------------------------------------------------------
# Remote proof server instead of the local docker one on :6300
#MIDNIGHT_PROOF_SERVER=http://127.0.0.1:6300
# Timeouts (ms): wallet sync / manual faucet funding wait / dust accrual wait
#MIDNIGHT_SYNC_TIMEOUT_MS=3600000
#NIGHT_FUND_TIMEOUT_MS=3600000
#DUST_TIMEOUT_MS=1800000
